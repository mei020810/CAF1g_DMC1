    parent=get_attr($9,"Parent")

    if($3=="gene" && id in target){
        print "###"
        keep[id]=1
        print
    }
    else if(parent!="" && parent_is_kept(parent)){
        if(id!=""){
            keep[id]=1
        }
        print
    }
}
