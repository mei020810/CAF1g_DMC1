calc_overlap () {
  condition=$1
  repA=$2
  repB=$3

  A=07_reproducibility_local_X800/peaks_sorted/${repA}.coord.sorted.narrowPeak
  B=07_reproducibility_local_X800/peaks_sorted/${repB}.coord.sorted.narrowPeak

  nA=$(wc -l < "$A")
  nB=$(wc -l < "$B")

  Aov=$(bedtools intersect -a "$A" -b "$B" -u | wc -l)
  Bov=$(bedtools intersect -a "$B" -b "$A" -u | wc -l)

  Apct=$(awk -v x="$Aov" -v n="$nA" 'BEGIN{if(n>0) printf "%.2f", x/n*100; else print "NA"}')
  Bpct=$(awk -v x="$Bov" -v n="$nB" 'BEGIN{if(n>0) printf "%.2f", x/n*100; else print "NA"}')

