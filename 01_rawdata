#提取fasta文件
conda install -c conda-forge -c bioconda biopython
python - <<'PY'
import re
import gzip

embl_file = "TAIR12_1Feb26.embl"
out_file = "TAIR12_1Feb26.Chr.fa"

def open_text(path):
    if path.endswith(".gz"):
        return gzip.open(path, "rt")
    return open(path, "r")

records = []
chrom = None
seq_parts = []
in_seq = False
expected_len = None

with open_text(embl_file) as f:
    for line in f:
        if line.startswith("ID"):
            chrom = None
            seq_parts = []
            in_seq = False
            expected_len = None

            m = re.search(r";\s*(\d+)\s+BP\.", line)
            if m:
                expected_len = int(m.group(1))

        elif line.startswith("AC") and "_Chr" in line:
            m = re.search(r"_(Chr[1-5])\b", line)
            if m:
                chrom = m.group(1)

        elif line.startswith("SQ"):
            in_seq = True

        elif line.startswith("//"):
            if chrom is None:
                raise ValueError("No chromosome name found for one EMBL record")

            seq = "".join(seq_parts).upper()

            if expected_len is not None and len(seq) != expected_len:
                raise ValueError(
                    f"Length mismatch for {chrom}: extracted {len(seq)}, expected {expected_len}"
                )

            records.append((chrom, seq))
            chrom = None
            seq_parts = []
            in_seq = False
            expected_len = None

        elif in_seq:
            # EMBL sequence lines contain bases plus spaces and a terminal count.
            bases = re.findall(r"[A-Za-z]+", line)
            seq_parts.append("".join(bases))

# sort Chr1-Chr5
records = sorted(records, key=lambda x: int(x[0].replace("Chr", "")))

chroms = [r[0] for r in records]
if chroms != ["Chr1", "Chr2", "Chr3", "Chr4", "Chr5"]:
    raise ValueError(f"Unexpected chromosome set/order: {chroms}")

with open(out_file, "w") as out:
    for chrom, seq in records:
        out.write(f">{chrom}\n")
        for i in range(0, len(seq), 60):
            out.write(seq[i:i+60] + "\n")

print(f"Wrote {out_file}")
for chrom, seq in records:
    print(chrom, len(seq))
print("total", sum(len(seq) for _, seq in records))
PY
