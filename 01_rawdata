#!/usr/bin/env python3

import os
import re
import argparse
import pandas as pd
from collections import defaultdict

def read_table(path, sheet=0):
    lower = path.lower()
    if lower.endswith(".xlsx") or lower.endswith(".xls"):
        return pd.read_excel(path, sheet_name=sheet, dtype=str)
    elif lower.endswith(".csv"):
        return pd.read_csv(path, dtype=str)
    else:
        return pd.read_csv(path, sep="\t", dtype=str)

def load_map(path):
    # columns: Araport11_ID, TAIR12_ID, TAIR12_Type, Araport11_Type, Status
    mp = defaultdict(set)
    status = defaultdict(set)

    with open(path) as f:
        for line in f:
            parts = line.rstrip("\n").split("\t")
            if len(parts) < 5:
                continue
            araport, tair12, tair12_type, araport_type, st = parts[:5]
            if araport in {"", "-", "NA"} or tair12 in {"", "-", "NA"}:
                continue
            mp[araport.upper()].add(tair12.upper())
            status[araport.upper()].add(st)

    return mp, status

def load_background(path):
    bg = set()
    with open(path) as f:
        for line in f:
            x = line.strip().upper()
            if x:
                bg.add(x)
    return bg

def extract_gene_ids(x):
    if pd.isna(x):
        return []
    text = str(x).upper()
    # 抓 AT1G18820、AT4R000063 这类 nuclear gene/locus IDs
    pat = re.compile(r"AT[1-5][A-Z][0-9]{5,6}(?:\.[0-9]+)?", re.I)
    ids = []
    for m in pat.findall(text):
        g = re.sub(r"\.[0-9]+$", "", m.upper())
        ids.append(g)
    return ids

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--input", required=True, help="customer table: xlsx/csv/tsv")
    parser.add_argument("--map", required=True, help="Araport11_to_TAIR12.ID_map.clean.tsv")
    parser.add_argument("--background", required=False, help="optional TAIR12 background IDs; used to keep already-TAIR12 IDs")
    parser.add_argument("--outdir", required=True)
    parser.add_argument("--sheet", default=0)
    args = parser.parse_args()

    os.makedirs(args.outdir, exist_ok=True)
    list_dir = os.path.join(args.outdir, "TAIR12_gene_lists_by_column")
    os.makedirs(list_dir, exist_ok=True)

    df = read_table(args.input, sheet=args.sheet)
    mp, map_status = load_map(args.map)
    bg = load_background(args.background) if args.background else set()

    converted_df = pd.DataFrame(index=df.index)
    detail_rows = []
    summary_rows = []

    for col in df.columns:
        col_converted_cells = []
        col_raw_ids = set()
        col_tair12_ids = set()
        col_unmapped = set()
        col_multimap = set()
        col_kept = set()

        for idx, val in df[col].items():
            raw_ids = extract_gene_ids(val)
            mapped_for_cell = []

            for raw in raw_ids:
                col_raw_ids.add(raw)

                if raw in mp:
                    targets = sorted(mp[raw])
                    mapped_for_cell.extend(targets)
                    col_tair12_ids.update(targets)

                    if len(targets) > 1:
                        col_multimap.add(raw)

                    for t in targets:
                        detail_rows.append({
                            "dataset": col,
                            "row_index": idx + 1,
                            "original_id": raw,
                            "TAIR12_ID": t,
                            "mapping_type": "mapped_from_Araport11",
                            "map_status": ";".join(sorted(map_status.get(raw, [])))
                        })

                elif raw in bg:
                    # 这个 ID 已经是 TAIR12 background 中的合法 ID，保留
                    mapped_for_cell.append(raw)
                    col_tair12_ids.add(raw)
                    col_kept.add(raw)

                    detail_rows.append({
                        "dataset": col,
                        "row_index": idx + 1,
                        "original_id": raw,
                        "TAIR12_ID": raw,
                        "mapping_type": "kept_as_TAIR12_or_shared_ID",
                        "map_status": "not_in_map_but_in_TAIR12_background"
                    })

                else:
                    col_unmapped.add(raw)

                    detail_rows.append({
                        "dataset": col,
                        "row_index": idx + 1,
                        "original_id": raw,
                        "TAIR12_ID": "",
                        "mapping_type": "unmapped",
                        "map_status": "not_in_map_or_background"
                    })

            mapped_for_cell = sorted(set(mapped_for_cell))
            col_converted_cells.append(";".join(mapped_for_cell))

        converted_df[col] = col_converted_cells

        safe_col = re.sub(r"[^A-Za-z0-9_.-]+", "_", str(col))
        list_file = os.path.join(list_dir, f"{safe_col}.TAIR12_IDs.txt")

        with open(list_file, "w") as out:
            for g in sorted(col_tair12_ids):
                out.write(g + "\n")

        summary_rows.append({
            "dataset": col,
            "raw_unique_ids": len(col_raw_ids),
            "TAIR12_unique_ids": len(col_tair12_ids),
            "kept_as_TAIR12_or_shared_IDs": len(col_kept),
            "original_IDs_with_multiple_TAIR12_targets": len(col_multimap),
            "unmapped_unique_ids": len(col_unmapped),
            "TAIR12_gene_list_file": list_file
        })

    converted_df.to_csv(os.path.join(args.outdir, "June9_39cols.converted_to_TAIR12.wide.tsv"), sep="\t", index=False)

    pd.DataFrame(detail_rows).to_csv(
        os.path.join(args.outdir, "June9_39cols.Araport11_to_TAIR12.mapping_detail.tsv"),
        sep="\t",
        index=False
    )

    pd.DataFrame(summary_rows).to_csv(
        os.path.join(args.outdir, "June9_39cols.Araport11_to_TAIR12.mapping_summary.tsv"),
        sep="\t",
        index=False
    )

    print("Done.")
    print("Converted wide table:", os.path.join(args.outdir, "June9_39cols.converted_to_TAIR12.wide.tsv"))
    print("Mapping detail:", os.path.join(args.outdir, "June9_39cols.Araport11_to_TAIR12.mapping_detail.tsv"))
    print("Mapping summary:", os.path.join(args.outdir, "June9_39cols.Araport11_to_TAIR12.mapping_summary.tsv"))
    print("Per-column TAIR12 gene lists:", list_dir)

if __name__ == "__main__":
    main()
