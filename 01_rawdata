function get_attr(attr,key,    n,a,i,kv){
    n=split(attr,a,";")
    for(i=1;i<=n;i++){
        split(a[i],kv,"=")
        if(kv[1]==key){
            return kv[2]
        }
    }
    return ""
}

function parent_is_kept(parent,    n,p,i){
    n=split(parent,p,",")
    for(i=1;i<=n;i++){
        if(p[i] in keep){
            return 1
        }
    }
    return 0
}

$0 ~ /^#/ {
    next
}

