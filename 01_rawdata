#!/usr/bin/env python3

import argparse
import os
import re
import numpy as np
import pandas as pd

gene_pattern = re.compile(r"AT[1-5]G[0-9]{5}(?:\.[0-9]+)?", re.IGNORECASE)

def extract_genes_from_text(x):
    if pd.isna(x):
        return set()
    genes = set()
    for m in gene_pattern.findall(str(x)):
        g = re.sub(r"\.[0-9]+$", "", m.upper())
        genes.add(g)
    return genes

def read_gene_file(path):
    genes = set()
    with open(path) as f:
        for line in f:
            genes |= extract_genes_from_text(line.strip())
    return genes

def read_reference_table(path, sheet=0):
    lower = path.lower()
    if lower.endswith(".xlsx") or lower.endswith(".xls"):
        return pd.read_excel(path, sheet_name=sheet, dtype=str)
    elif lower.endswith(".csv"):
        return pd.read_csv(path, dtype=str)
    else:
        return pd.read_csv(path, sep="\t", dtype=str)

def bh_adjust(pvals):
    pvals = np.asarray(pvals, dtype=float)
    n = len(pvals)
    order = np.argsort(pvals)
    ranked = pvals[order]
    adj = np.empty(n, dtype=float)
    prev = 1.0
    for i in range(n - 1, -1, -1):
        rank = i + 1
        val = ranked[i] * n / rank
        prev = min(prev, val)
        adj[order[i]] = min(prev, 1.0)
    return adj

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--query", required=True, help="Query gene list, one gene per line or mixed text.")
    parser.add_argument("--reference", required=True, help="39-column reference gene-list table, tsv/csv/xlsx.")
    parser.add_argument("--background", required=True, help="Background gene list.")
    parser.add_argument("--outdir", required=True)
    parser.add_argument("--nperm", type=int, default=10000)
    parser.add_argument("--seed", type=int, default=1)
    parser.add_argument("--sheet", default=0, help="Excel sheet index/name. Default: 0")
    args = parser.parse_args()

    os.makedirs(args.outdir, exist_ok=True)
    overlap_dir = os.path.join(args.outdir, "overlap_genes_by_dataset")
    os.makedirs(overlap_dir, exist_ok=True)

    rng = np.random.default_rng(args.seed)

    background = read_gene_file(args.background)
    query_raw = read_gene_file(args.query)
    query = query_raw & background

    bg_list = np.array(sorted(background))
    bg_n = len(background)
    query_n_raw = len(query_raw)
    query_n = len(query)

    if query_n == 0:
        raise ValueError("No query genes remain after filtering by background.")

    ref_df = read_reference_table(args.reference, sheet=args.sheet)

    rows = []
    random_count_matrix = {}

    for col in ref_df.columns:
        ref_raw = set()
        for x in ref_df[col]:
            ref_raw |= extract_genes_from_text(x)

        ref = ref_raw & background
        ref_n_raw = len(ref_raw)
        ref_n = len(ref)

        if ref_n == 0:
            obs = 0
            expected_formula = 0.0
            random_counts = np.zeros(args.nperm, dtype=int)
            random_mean = 0.0
            random_sd = 0.0
            fe = np.nan
            direction = "NA"
            p_emp = np.nan
            overlap = set()
        else:
            overlap = query & ref
            obs = len(overlap)

            expected_formula = query_n * ref_n / bg_n

            random_counts = np.empty(args.nperm, dtype=int)
            ref_set = set(ref)

            for i in range(args.nperm):
                rand_query = set(rng.choice(bg_list, size=query_n, replace=False))
                random_counts[i] = len(rand_query & ref_set)

            random_mean = float(np.mean(random_counts))
            random_sd = float(np.std(random_counts, ddof=1))

            if random_mean > 0:
                fe = obs / random_mean
            else:
                fe = np.inf if obs > 0 else np.nan

            if obs >= random_mean:
                direction = "+"
                p_emp = (np.sum(random_counts >= obs) + 1) / (args.nperm + 1)
            else:
                direction = "-"
                p_emp = (np.sum(random_counts <= obs) + 1) / (args.nperm + 1)

        safe_col = re.sub(r"[^A-Za-z0-9_.-]+", "_", str(col))
        overlap_file = os.path.join(overlap_dir, f"{safe_col}.overlap_genes.txt")
        with open(overlap_file, "w") as out:
            for g in sorted(overlap):
                out.write(g + "\n")

        random_count_matrix[col] = random_counts

        rows.append({
            "dataset": col,
            "background_genes": bg_n,
            "query_genes_raw": query_n_raw,
            "query_genes_in_background": query_n,
            "reference_genes_raw": ref_n_raw,
            "reference_genes_in_background": ref_n,
            "observed_overlap": obs,
            "expected_overlap_formula": expected_formula,
            "expected_overlap_permutation_mean": random_mean,
            "random_overlap_sd": random_sd,
            "random_overlap_min": int(np.min(random_counts)),
            "random_overlap_max": int(np.max(random_counts)),
            "FE_observed_over_expected": fe,
            "enrichment_direction": direction,
            "empirical_p": p_emp,
            "overlap_gene_file": overlap_file
        })

    result = pd.DataFrame(rows)

    valid_p = result["empirical_p"].notna()
    result["empirical_p_BH"] = np.nan
    result.loc[valid_p, "empirical_p_BH"] = bh_adjust(result.loc[valid_p, "empirical_p"].values)

    result_file = os.path.join(args.outdir, "gene_level_enrichment_permutation_summary.tsv")
    result.to_csv(result_file, sep="\t", index=False)

    random_df = pd.DataFrame(random_count_matrix)
    random_df.index = np.arange(1, args.nperm + 1)
    random_df.index.name = "permutation"
    random_df.to_csv(os.path.join(args.outdir, "random_overlap_counts.tsv"), sep="\t")

    print("Done.")
    print("Summary:", result_file)
    print("Random overlap counts:", os.path.join(args.outdir, "random_overlap_counts.tsv"))
    print("Overlap gene lists:", overlap_dir)

if __name__ == "__main__":
    main()
EOF

